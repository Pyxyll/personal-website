---
interface Props {
  num: string;
  eyebrow?: string;
  title: string;
}
const { num, eyebrow, title } = Astro.props;
---

<header class="grid grid-cols-12 gap-6 lg:gap-10 items-baseline mb-10">
  <div class="hidden lg:block lg:col-span-2 section-num">{num}</div>
  <div class="col-span-12 lg:col-span-10 flex flex-col gap-3">
    {eyebrow && <div class="eyebrow">{eyebrow}</div>}
    <h2 class="text-[clamp(1.75rem,5vw,3rem)] font-bold tracking-tight leading-[0.95]">{title}</h2>
  </div>
</header>
