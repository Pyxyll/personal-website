---
import Base from "../../layouts/Base.astro";
import Schema from "../../components/Schema.astro";
import { webPageSchema, breadcrumbSchema } from "../../lib/schema";
import { site } from "../../lib/site";

const updatedDate = new Date("2026-05-29");
const updated = new Intl.DateTimeFormat("en-IE", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(updatedDate);
const isoUpdated = updatedDate.toISOString().split("T")[0];

const pageUrl = new URL("/now/", site.url).toString();
---

<Base
  title="Now · Dylan Collins"
  description="What I'm focused on right now."
>
  <Schema
    slot="head"
    data={[
      webPageSchema({
        url: pageUrl,
        name: "Now · Dylan Collins",
        description: "What I'm focused on right now.",
      }),
      breadcrumbSchema([
        { name: "Home", url: site.url + "/" },
        { name: "Now", url: pageUrl },
      ]),
    ]}
  />
  <section class="mx-auto max-w-6xl px-6 lg:px-10 py-16 sm:py-24">
    <header class="grid grid-cols-12 gap-6 lg:gap-10 mb-16 lg:mb-24">
      <div class="hidden lg:block lg:col-span-2 section-num lift">003 / Now</div>
      <div class="col-span-12 lg:col-span-10 flex flex-col gap-5">
        <h1 class="display text-[clamp(2.75rem,7vw,4.5rem)] lift lift-1">
          Now<span class="text-accent">.</span>
        </h1>
        <p class="text-lg text-ink-dim max-w-2xl lift lift-2">
          A <a href="https://nownownow.com/about" class="link" target="_blank" rel="noopener">/now</a> page:
          what I'm focused on right now, and what I'm not. The honest version,
          not what I want you to think I'm working on.
        </p>
        <div class="font-mono text-xs uppercase tracking-widest text-ink-faint lift lift-3">
          Last updated · <time datetime={isoUpdated}>{updated}</time>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Work</div>
      <div class="col-span-12 lg:col-span-10 prose">
        <p>
          Software developer at <strong>The B!G Idea</strong>, keeping our
          WordPress platform running while building its replacement.
        </p>
        <p>
          Outside of that, I like helping people build things. If you're working
          on something interesting and want a hand, <a href="/contact/">say hi</a>.
          Always happy to talk it through.
        </p>
      </div>
    </div>

    <div class="rule my-12 lg:my-16"></div>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Projects</div>
      <div class="col-span-12 lg:col-span-10 prose">
        <ul style="list-style:none;padding-left:0">
          <li><strong>VoxesDen</strong>: voice actors build voice cards to send to casting directors, played right in the browser. In progress.</li>
          <li><strong>Rust applets for COSMIC</strong>: small pieces for System76's desktop environment.</li>
          <li><strong><a href="https://pyxyll.com" target="_blank" rel="noopener">pyxyll.com</a></strong>: earmarked as the home for an indie-web project. Right now it's a domain and an idea, nothing more.</li>
          <li><strong>Linux desktop tinkering</strong>: an endless rabbit hole I've made peace with running for the rest of my life.</li>
        </ul>
      </div>
    </div>

    <div class="rule my-12 lg:my-16"></div>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Off</div>
      <div class="col-span-12 lg:col-span-10 prose">
        <p>
          Coffee, cats, gaming, 3D printing, and a pile of other hobbies I
          don't get to nearly enough.
        </p>
      </div>
    </div>
  </section>
</Base>
