---
import Base from "../../layouts/Base.astro";
import Schema from "../../components/Schema.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCollection } from "astro:content";
import { collectionPageSchema, breadcrumbSchema } from "../../lib/schema";
import { site } from "../../lib/site";

const entries = (await getCollection("work")).sort(
  (a, b) => +b.data.publishedAt - +a.data.publishedAt
);

// Group by category, preserving the date sort within each. Known categories
// render in this order; anything new falls in after, alphabetically.
const CATEGORY_ORDER = ["Web apps", "Sites", "COSMIC", "Homelab"];
const groups = entries.reduce<Record<string, typeof entries>>((acc, e) => {
  (acc[e.data.category] ??= []).push(e);
  return acc;
}, {});
const cats = [
  ...CATEGORY_ORDER.filter((c) => groups[c]),
  ...Object.keys(groups).filter((c) => !CATEGORY_ORDER.includes(c)).sort(),
];

const pageUrl = new URL("/work/", site.url).toString();
const pageTitle = "Work · Dylan Collins";
const pageDesc = "Things I've built: COSMIC applets, web apps, and a few self-hosted experiments.";
---

<Base title={pageTitle} description={pageDesc}>
  <Schema
    slot="head"
    data={[
      collectionPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc }),
      breadcrumbSchema([
        { name: "Home", url: site.url + "/" },
        { name: "Work", url: pageUrl },
      ]),
    ]}
  />
  <section class="mx-auto max-w-6xl px-6 lg:px-10 py-16 sm:py-24">
    <header class="grid grid-cols-12 gap-6 lg:gap-10 mb-16 lg:mb-24">
      <div class="hidden lg:block lg:col-span-2 section-num lift">001 / Work</div>
      <div class="col-span-12 lg:col-span-10 flex flex-col gap-5">
        <h1 class="display text-[clamp(2.75rem,7vw,4.5rem)] lift lift-1">
          Work<span class="text-accent">.</span>
        </h1>
        <p class="text-lg text-ink-dim max-w-2xl lift lift-2">
          A short list of things I've built, for work, for fun, and for people
          who needed a hand. If something here overlaps with what you're making,
          <a href="/contact/" class="link">say hi</a>.
        </p>

      </div>
    </header>

    {entries.length === 0 ? (
      <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
        <div class="col-span-12 lg:col-span-2 hidden lg:block"></div>
        <div class="col-span-12 lg:col-span-10">
          <EmptyState
            label="In progress"
            message="Case studies are being written up. In the meantime, reach out and I'll send recent samples."
            ctaHref="/contact/"
            ctaLabel="Get in touch"
          />
        </div>
      </div>
    ) : (
      cats.map((cat) => (
        <section class="mb-12" data-reveal>
          <div class="grid grid-cols-12 gap-6 lg:gap-10 mb-4 items-baseline">
            <h2 class="col-span-12 lg:col-span-2 font-mono text-xs uppercase tracking-widest text-ink-faint font-normal m-0">
              {cat}
            </h2>
            <div class="col-span-12 lg:col-span-10 rule"></div>
          </div>
          <ul class="grid grid-cols-12 gap-6 lg:gap-10">
            <li class="col-span-12 lg:col-span-2 hidden lg:block"></li>
            <li class="col-span-12 lg:col-span-10">
              <ul class="divide-y divide-rule">
                {groups[cat].map((entry) => {
                  const year = entry.data.publishedAt.getFullYear();
                  const iso = entry.data.publishedAt.toISOString().split("T")[0];
                  return (
                  <li class="group py-6 px-2 -mx-2 transition-colors hover:bg-paper-2">
                    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                      <h3 class="text-[clamp(1.375rem,3.5vw,1.875rem)] font-semibold tracking-tight m-0">
                        <a href={`/work/${entry.id}/`} class="hover:text-accent transition-colors">
                          {entry.data.title}
                          <span class="ml-3 text-accent inline-block group-hover:translate-x-1 transition-transform">→</span>
                        </a>
                      </h3>
                      <span class="font-mono text-xs text-ink-faint tracking-widest uppercase shrink-0">
                        {entry.data.role ?? ""} {entry.data.role && "·"} <time datetime={iso}>{year}</time>
                      </span>
                    </div>
                    <p class="text-ink-dim text-sm sm:text-base max-w-2xl mt-2">{entry.data.summary}</p>
                    {(entry.data.stack.length > 0 || entry.data.repo || entry.data.url) && (
                      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-[11px] uppercase tracking-widest text-ink-faint mt-3">
                        {entry.data.stack.length > 0 && <span>{entry.data.stack.join(" · ")}</span>}
                        {entry.data.repo && (
                          <a href={entry.data.repo} target="_blank" rel="noopener" class="link text-ink-dim hover:text-ink">GitHub ↗</a>
                        )}
                        {entry.data.url && (
                          <a href={entry.data.url} target="_blank" rel="noopener" class="link text-ink-dim hover:text-ink">Visit ↗</a>
                        )}
                      </div>
                    )}
                  </li>
                  );
                })}
              </ul>
            </li>
          </ul>
        </section>
      ))
    )}
  </section>
</Base>
