---
import Base from "../../layouts/Base.astro";
import Schema from "../../components/Schema.astro";
import { getCollection } from "astro:content";
import { collectionPageSchema, breadcrumbSchema } from "../../lib/schema";
import { site } from "../../lib/site";

const entries = (await getCollection("work")).sort(
  (a, b) => a.data.order - b.data.order || b.data.year - a.data.year
);

const pageUrl = new URL("/work/", site.url).toString();
const pageTitle = "Work — Dylan Collins";
const pageDesc = "Selected client work, freelance projects, and things I've shipped.";
---

<Base title={pageTitle} description={pageDesc}>
  <Schema
    slot="head"
    data={[
      collectionPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc }),
      breadcrumbSchema([
        { name: "Home", url: site.url + "/" },
        { name: "Work", url: pageUrl },
      ]),
    ]}
  />
  <section class="mx-auto max-w-6xl px-6 lg:px-10 py-16 sm:py-24">
    <header class="grid grid-cols-12 gap-6 lg:gap-10 mb-16 lg:mb-24">
      <div class="hidden lg:block lg:col-span-2 section-num lift">001 / Work</div>
      <div class="col-span-12 lg:col-span-10 flex flex-col gap-5">
        <h1 class="display text-[clamp(2.75rem,7vw,4.5rem)] lift lift-1">
          Work<span class="text-accent">.</span>
        </h1>
        <p class="text-lg text-ink-dim max-w-2xl lift lift-2">
          A short list. Freelance and full-time. Most of it Laravel, Next.js,
          React Native, and a lot of Postgres. Reach out if anything overlaps
          with what you're building.
        </p>
      </div>
    </header>

    {entries.length === 0 ? (
      <p class="text-ink-dim">Nothing public yet. Drop me a line and I'll send recent samples.</p>
    ) : (
    <ul class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <li class="col-span-12 lg:col-span-2 hidden lg:block"></li>
      <li class="col-span-12 lg:col-span-10">
        <ul class="divide-y divide-rule border-y border-rule">
          {entries.map((entry, i) => (
            <li>
              <a
                href={`/work/${entry.id}/`}
                class="group block py-6 sm:py-8 px-2 -mx-2 transition-colors hover:bg-paper-2"
              >
                <div class="grid grid-cols-12 gap-x-3 gap-y-2 items-baseline">
                  <span class="col-span-2 sm:col-span-1 font-mono text-xs text-ink-faint tracking-widest">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="col-span-10 sm:col-span-7 text-[clamp(1.375rem,3.5vw,1.875rem)] font-semibold tracking-tight">
                    {entry.data.title}
                    <span class="ml-3 text-accent inline-block group-hover:translate-x-1 transition-transform">→</span>
                  </span>
                  <span class="col-span-12 sm:col-span-4 sm:text-right font-mono text-xs text-ink-faint tracking-widest uppercase">
                    {entry.data.role ?? ""} {entry.data.role && "·"} <time datetime={String(entry.data.year)}>{entry.data.year}</time>
                  </span>
                </div>
                <div class="grid grid-cols-12 gap-x-3 mt-3">
                  <span class="hidden sm:block sm:col-span-1"></span>
                  <span class="col-span-12 sm:col-span-11 text-ink-dim text-sm sm:text-base max-w-2xl">
                    {entry.data.summary}
                  </span>
                </div>
                {entry.data.stack.length > 0 && (
                  <div class="grid grid-cols-12 gap-x-3 mt-3">
                    <span class="hidden sm:block sm:col-span-1"></span>
                    <span class="col-span-12 sm:col-span-11 font-mono text-[11px] uppercase tracking-widest text-ink-faint">
                      {entry.data.stack.join(" · ")}
                    </span>
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </li>
    </ul>
    )}
  </section>
</Base>
