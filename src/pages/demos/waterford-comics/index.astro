---
/**
 * Spec concept for Waterford Comics — an unsolicited design sent to the shop.
 *
 * Deliberately lives under /demos/ rather than in the `work` content
 * collection: nothing here was commissioned, so it must not appear in the work
 * index alongside real client projects. It is also noindexed, so it can't
 * compete with the shop's own presence in search.
 *
 * Ported from a Claude Design file. The design tool's own syntax (sc-if,
 * style-hover, style-before, DCLogic) has no runtime here, so conditionals
 * became media queries plus a little vanilla JS, and the pseudo-element and
 * hover styles became real CSS. Everything is namespaced under .wc so the
 * demo's visual world stays sealed off from the site's.
 */
import Demo from "../../../layouts/Demo.astro";

const pageTitle = "Waterford Comics · Site concept · Dylan Collins";
const pageDesc =
  "An unsolicited website concept for Waterford Comics — a family-run comic, manga and collectibles shop on Newtown Road.";
---

<Demo title={pageTitle} description={pageDesc} background="#fbf7ee" noindex>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="wc">
    {/* Displacement filters that give every border its hand-inked wobble. */}
    <svg aria-hidden="true" width="0" height="0" style="position:absolute;pointer-events:none;">
      <defs>
        <filter id="rough" x="-30%" y="-30%" width="160%" height="160%">
          <feTurbulence type="fractalNoise" baseFrequency="0.006" numOctaves="1" seed="7" result="n"></feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"></feDisplacementMap>
        </filter>
        <filter id="rough-fine" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.022" numOctaves="2" seed="4" result="n"></feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="n" scale="1.8"></feDisplacementMap>
        </filter>
      </defs>
    </svg>

    {/* ===================== NAV ===================== */}
    <header class="wc-header">
      <nav class="wc-nav">
        <a href="#top" class="wc-logo">
          <span>Waterford</span>
          <span class="wc-logo-accent">Comics</span>
          <span class="wc-logo-dot"></span>
        </a>

        <div class="wc-nav-desktop">
          <a href="#shop" class="wc-navlink">Shop</a>
          <a href="#pulllist" class="wc-navlink">Pull List</a>
          <a href="#cafe" class="wc-navlink">Café</a>
          <a href="#events" class="wc-navlink">Events</a>
          <a href="#visit" class="wc-navlink">Visit</a>
          <span class="wc-btnwrap" data-anglebtn data-drop="#15121d" data-off="6,8">
            <a
              href="#pulllist"
              class="wc-btn"
              style="--ax:6px;--ay:7px;font-size:13px;letter-spacing:.1em;background:#e63a2e;color:#fbf7ee;padding:9px 16px;"
              >Join the Pull List</a
            >
          </span>
        </div>

        <button class="wc-burger" aria-label="Menu" aria-expanded="false" aria-controls="wc-menu" data-menu-toggle>
          <span></span><span></span><span></span>
        </button>
      </nav>

      <div class="wc-menu" id="wc-menu" hidden>
        <a href="#shop" class="wc-menulink" data-menu-close>Shop</a>
        <a href="#pulllist" class="wc-menulink" data-menu-close>Pull List</a>
        <a href="#cafe" class="wc-menulink" data-menu-close>Café</a>
        <a href="#events" class="wc-menulink" data-menu-close>Events</a>
        <a href="#visit" class="wc-menulink" data-menu-close>Visit</a>
        <a href="#pulllist" class="wc-menucta" data-menu-close>Join the Pull List</a>
      </div>
    </header>

    {/* ===================== HERO ===================== */}
    <section id="top" class="wc-hero">
      <div aria-hidden="true" class="wc-dots wc-dots-hero"></div>
      <div class="wc-hero-inner">
        <div>
          <div class="wc-eyebrow" style="color:#e63a2e;margin-bottom:22px;">
            Family-run · Newtown Road, Waterford
          </div>
          <h1 class="wc-h1">
            Your local for<br />
            <span class="wc-h1-mark">comics</span>
            <span> &amp;</span><br />
            collectibles
          </h1>
          <p class="wc-hero-lede">
            Comics and graphic novels, manga, trading cards, figures and merch — stacked floor to
            ceiling, with people who actually know the stock. Sit in, read, and pull your weekly
            titles.
          </p>
          <div class="wc-hero-btns">
            <span class="wc-btnwrap" data-anglebtn data-drop="#fbf7ee" data-off="9,11">
              <a
                href="#shop"
                class="wc-btn"
                style="--ax:9px;--ay:10px;font-size:14px;letter-spacing:.08em;background:#e63a2e;color:#fbf7ee;border-color:#fbf7ee;padding:15px 26px;"
                >Browse the shop</a
              >
            </span>
            <span class="wc-btnwrap" data-anglebtn data-drop="#e63a2e" data-off="9,11">
              <a
                href="#pulllist"
                class="wc-btn"
                style="--ax:9px;--ay:10px;font-size:14px;letter-spacing:.08em;background:#15121d;color:#fbf7ee;border-color:#fbf7ee;padding:15px 26px;"
                >Start a pull list</a
              >
            </span>
          </div>
          {/* Review count is placeholder copy from the concept — verify against
              the shop's actual Google listing before this goes to them. */}
          <div class="wc-rating">
            <span style="color:#e63a2e;font-size:16px;letter-spacing:.1em;">★★★★</span>
            <span>Rated by locals on Google · Shop local, get looked after</span>
          </div>
        </div>

        <div class="wc-hero-aside">
          <div class="wc-bubble">
            <div class="wc-eyebrow" style="font-size:11px;color:#e63a2e;margin-bottom:6px;">
              New comic day
            </div>
            <div class="wc-bubble-text">
              Fresh comics land every Wednesday — first dibs to pull-list members
            </div>
            <div class="wc-bubble-tail-outer"></div>
            <div class="wc-bubble-tail-inner"></div>
          </div>
          <div class="wc-stamp">EST. ON NEWTOWN ROAD</div>
        </div>
      </div>
    </section>

    {/* ===================== NEW THIS WEEK ===================== */}
    <section id="shop" class="wc-band">
      <div aria-hidden="true" class="wc-dots wc-dots-band"></div>
      <div class="wc-band-inner">
        <div class="wc-band-head">
          <div>
            <div class="wc-eyebrow" style="color:#15121d;margin-bottom:8px;">New this week</div>
            <h2 class="wc-h2">On the shelf now</h2>
          </div>
          <span class="wc-btnwrap" data-anglebtn data-drop="#15121d" data-off="7,9">
            <a
              href="#pulllist"
              class="wc-btn"
              style="--ax:7px;--ay:8px;font-size:12.5px;letter-spacing:.08em;background:#fbf7ee;color:#15121d;padding:11px 18px;"
              >Pull these for me →</a
            >
          </span>
        </div>

        <div class="wc-grid-cards">
          <div class="wc-tilt" style="--rot:-1.6deg">
            <div class="wc-card" data-wc-reveal>
              <div class="wc-cover" style="background:linear-gradient(135deg,#e63a2e 0%,#15121d 100%);">
                <span class="wc-tag">New series</span>
                <span class="wc-issue" style="font-size:34px;color:rgba(251,247,238,.85);">#1</span>
              </div>
              <div class="wc-cardbody">
                <div class="wc-cardtitle">The Tin Lighthouse</div>
                <div class="wc-cardmeta">Indie · sci-fi</div>
                <div class="wc-price">€4.50</div>
              </div>
            </div>
          </div>

          <div class="wc-tilt" style="--rot:1.3deg">
            <div class="wc-card" data-wc-reveal>
              <div class="wc-cover" style="background:linear-gradient(135deg,#15121d 0%,#e63a2e 100%);">
                <span class="wc-tag">Restock</span>
                <span class="wc-issue" style="font-size:30px;color:rgba(21,18,29,.7);">V3</span>
              </div>
              <div class="wc-cardbody">
                <div class="wc-cardtitle">Hollowpoint</div>
                <div class="wc-cardmeta">Graphic novel</div>
                <div class="wc-price">€12.99</div>
              </div>
            </div>
          </div>

          <div class="wc-tilt" style="--rot:-0.9deg">
            <div class="wc-card" data-wc-reveal>
              <div class="wc-cover" style="background:linear-gradient(135deg,#e63a2e 0%,#211c2e 100%);">
                <span class="wc-tag">Pre-order</span>
                <span class="wc-issue" style="font-size:34px;color:rgba(251,247,238,.85);">#7</span>
              </div>
              <div class="wc-cardbody">
                <div class="wc-cardtitle">Saltwater Saints</div>
                <div class="wc-cardmeta">Ongoing · fantasy</div>
                <div class="wc-price">€4.99</div>
              </div>
            </div>
          </div>

          <div class="wc-tilt" style="--rot:1.6deg">
            <div class="wc-card" data-wc-reveal>
              <div class="wc-cover" style="background:linear-gradient(135deg,#211c2e 0%,#e63a2e 100%);">
                <span class="wc-tag">Singles</span>
                <span class="wc-issue" style="font-size:26px;color:rgba(21,18,29,.7);">TCG</span>
              </div>
              <div class="wc-cardbody">
                <div class="wc-cardtitle">Foil singles bag</div>
                <div class="wc-cardmeta">Trading cards</div>
                <div class="wc-price">€6.00</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== DIAGONAL RIBBON ===================== */}
    <div aria-hidden="true" class="wc-ribbon-slot">
      <div class="wc-ribbon">
        <div class="wc-ribbon-text">
          New comics every Wednesday&nbsp;&nbsp;✦&nbsp;&nbsp;First dibs for
          members&nbsp;&nbsp;✦&nbsp;&nbsp;Singles · sealed · figures ·
          manga&nbsp;&nbsp;✦&nbsp;&nbsp;Café next door&nbsp;&nbsp;✦&nbsp;&nbsp;Shop local, get
          looked after&nbsp;&nbsp;✦
        </div>
      </div>
    </div>

    {/* ===================== WHAT WE STOCK ===================== */}
    <section class="wc-stock">
      <div class="wc-stock-inner">
        <div style="margin-bottom:30px;">
          <div class="wc-eyebrow" style="color:#e63a2e;margin-bottom:8px;">What we stock</div>
          <h2 class="wc-h2">Six aisles, one nerd haven</h2>
        </div>

        <div class="wc-panelgrid">
          <div class="wc-panel" data-wc-reveal>
            <div class="wc-panelicon">
              <svg width="34" height="34" viewBox="0 0 56 56" fill="none" stroke="#fbf7ee" stroke-width="3"
                ><rect x="14" y="13" width="20" height="26" rx="2" /><rect x="22" y="19" width="20" height="26" rx="2" /></svg
              >
            </div>
            <div class="wc-paneltitle">Comics &amp; graphic novels</div>
            <p class="wc-panelbody">
              Single issues, trades and original graphic novels — indie shelves alongside the big
              runs.
            </p>
          </div>

          <div class="wc-panel" data-wc-reveal>
            <div class="wc-panelicon">
              <svg width="34" height="34" viewBox="0 0 56 56" fill="none" stroke="#fbf7ee" stroke-width="3"
                ><rect x="12" y="14" width="32" height="22" rx="4" /><path d="M20 36 v8 l9 -8" /></svg
              >
            </div>
            <div class="wc-paneltitle">Manga &amp; anime</div>
            <p class="wc-panelbody">
              Shonen to seinen, new volumes weekly, plus art books and anime merch.
            </p>
          </div>

          <div class="wc-panel" data-wc-reveal>
            <div class="wc-panelicon">
              <svg width="34" height="34" viewBox="0 0 56 56" fill="none" stroke="#fbf7ee" stroke-width="3"
                ><rect x="16" y="16" width="24" height="24" rx="3" transform="rotate(45 28 28)" /></svg
              >
            </div>
            <div class="wc-paneltitle">Trading cards &amp; TCG</div>
            <p class="wc-panelbody">
              Singles and sealed across the major games — bring a deck, we run league nights.
            </p>
          </div>

          <div class="wc-panel" data-wc-reveal>
            <div class="wc-panelicon">
              <svg width="34" height="34" viewBox="0 0 56 56" fill="none" stroke="#fbf7ee" stroke-width="3"
                ><circle cx="28" cy="19" r="7" /><path d="M17 44 q11 -17 22 0" /></svg
              >
            </div>
            <div class="wc-paneltitle">Figures &amp; toys</div>
            <p class="wc-panelbody">
              Collectible figures, blind boxes and statues — display pieces and pocket-money picks.
            </p>
          </div>

          <div class="wc-panel" data-wc-reveal>
            <div class="wc-panelicon">
              <svg width="34" height="34" viewBox="0 0 56 56" fill="none" stroke="#fbf7ee" stroke-width="3"
                ><path d="M17 17 h14 l11 11 -15 15 -11 -11 z" /><circle cx="25" cy="25" r="2.6" /></svg
              >
            </div>
            <div class="wc-paneltitle">Merch &amp; apparel</div>
            <p class="wc-panelbody">
              Tees, pins, prints and posters — wear the fandom, no logos required.
            </p>
          </div>

          <div class="wc-panel" data-wc-reveal>
            <div class="wc-panelicon">
              <svg width="34" height="34" viewBox="0 0 56 56" fill="none" stroke="#fbf7ee" stroke-width="3"
                ><rect x="15" y="22" width="22" height="18" rx="3" /><path d="M37 26 h5 a4 4 0 0 1 0 8 h-5" /><path
                  d="M21 12 v5 M29 12 v5"
                /></svg
              >
            </div>
            <div class="wc-paneltitle">The café next door</div>
            <p class="wc-panelbody">
              Same owners, one door over. Buy a book, grab a coffee, sit and actually read it.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== PULL LIST ===================== */}
    <section id="pulllist" class="wc-pull">
      <div aria-hidden="true" class="wc-dots wc-dots-pull"></div>
      <div class="wc-pull-inner">
        <div>
          <div class="wc-eyebrow" style="letter-spacing:.18em;color:#e63a2e;margin-bottom:16px;">
            ★ The pull list · our flagship
          </div>
          <h2 class="wc-h2 wc-h2-big">Never miss an issue again</h2>
          <p class="wc-pull-lede">
            A pull list is your standing weekly order. Tell us the titles you follow and we set a
            copy aside every Wednesday — held behind the counter with your name on it. No app, no
            subscription fee, no sold-out heartbreak.
          </p>
          <div class="wc-ticks">
            <div class="wc-tick"><span class="wc-tickmark">✓</span><span>Reserved for you, every week</span></div>
            <div class="wc-tick"><span class="wc-tickmark">✓</span><span>First dibs on new-comic Wednesday</span></div>
            <div class="wc-tick"><span class="wc-tickmark">✓</span><span>Members' discount on your pulls</span></div>
            <div class="wc-tick"><span class="wc-tickmark">✓</span><span>Pause or cancel anytime</span></div>
          </div>
        </div>

        <div class="wc-membercard">
          <div class="wc-memberbadge">Member card</div>
          <div style="display:flex;align-items:baseline;gap:10px;">
            <span class="wc-price-big">€0</span>
            <span class="wc-eyebrow" style="font-size:13px;letter-spacing:.08em;color:#6b6478;">to join</span>
          </div>
          <p style="font-size:14.5px;color:#3a3447;margin:8px 0 22px;">
            You only ever pay for the books you actually pull. Set it up in two minutes.
          </p>

          <form class="wc-form" data-pull-form>
            <label class="wc-field">
              <span class="wc-label">Your name</span>
              <input name="name" type="text" required placeholder="Jamie Power" class="wc-input" />
            </label>
            <label class="wc-field">
              <span class="wc-label">Email</span>
              <input name="email" type="email" required placeholder="you@email.ie" class="wc-input" />
            </label>
            <label class="wc-field">
              <span class="wc-label">Titles to pull</span>
              <input
                name="titles"
                type="text"
                placeholder="e.g. Saltwater Saints, Hollowpoint…"
                class="wc-input"
              />
            </label>
            <span class="wc-btnwrap" data-anglebtn data-drop="#15121d" data-off="8,10" style="display:block;margin-top:6px;">
              <button
                type="submit"
                class="wc-btn"
                style="--ax:8px;--ay:9px;width:100%;text-align:center;font-size:14px;letter-spacing:.08em;background:#e63a2e;color:#fbf7ee;padding:14px 18px;"
                >Set up my pull list</button
              >
            </span>
          </form>

          <div class="wc-confirm" aria-live="polite" data-pull-confirm hidden>
            <div class="wc-confirm-title">You're on the list!</div>
            <p style="margin:10px 0 0;font-size:14.5px;color:#3a3447;">
              That'd land in the shop's inbox — we'd start setting your titles aside this Wednesday.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== CAFÉ ===================== */}
    <section id="cafe" class="wc-cafe">
      <div class="wc-cafe-art">
        <div class="wc-cafe-dots"></div>
        <div class="wc-cafe-plaque">
          <div class="wc-eyebrow" style="font-size:11px;letter-spacing:.14em;margin-bottom:4px;">Next door</div>
          <div class="wc-cafe-plaque-title">Read &amp; refill</div>
        </div>
      </div>
      <div class="wc-cafe-body">
        <div class="wc-eyebrow" style="color:#e63a2e;margin-bottom:10px;">Comics + coffee</div>
        <h2 class="wc-h2" style="margin-bottom:18px;">Stay a while</h2>
        <p style="max-width:32em;font-size:17px;color:#3a3447;margin:0 0 26px;">
          The attached café is run by the same family. Pour-overs, pastries and a long table you're
          welcome to spread your stack across. Buy first, then read as long as you like — that's the
          whole point.
        </p>
        <span class="wc-btnwrap" data-anglebtn data-drop="#e63a2e" data-off="8,10" style="align-self:flex-start;">
          <a
            href="#visit"
            class="wc-btn"
            style="--ax:8px;--ay:9px;font-size:13px;letter-spacing:.08em;background:#15121d;color:#fbf7ee;padding:13px 22px;"
            >See café hours →</a
          >
        </span>
      </div>
    </section>

    {/* ===================== EVENTS ===================== */}
    <section id="events" class="wc-band">
      <div aria-hidden="true" class="wc-dots wc-dots-events"></div>
      <div class="wc-band-inner">
        <div style="margin-bottom:30px;">
          <div class="wc-eyebrow" style="color:#15121d;margin-bottom:8px;">What's on</div>
          <h2 class="wc-h2">The shop after hours</h2>
        </div>
        <div class="wc-grid-events">
          <div class="wc-tilt" style="--rot:1.4deg">
            <div class="wc-card wc-eventcard" data-wc-reveal>
              <div class="wc-eventwhen">Thursdays · 18:30</div>
              <div class="wc-eventtitle">TCG league night</div>
              <p class="wc-panelbody">
                Casual and ranked tables, all skill levels. Bring a deck or build one from singles on
                the night.
              </p>
            </div>
          </div>
          <div class="wc-tilt" style="--rot:-1.1deg">
            <div class="wc-card wc-eventcard" data-wc-reveal>
              <div class="wc-eventwhen">Saturdays · 11:00</div>
              <div class="wc-eventtitle">New-reader morning</div>
              <p class="wc-panelbody">
                Never read comics? Staff pick you a starting point over coffee. No question too
                basic.
              </p>
            </div>
          </div>
          <div class="wc-tilt" style="--rot:1.7deg">
            <div class="wc-card wc-eventcard" data-wc-reveal>
              <div class="wc-eventwhen">Last Sunday · 13:00</div>
              <div class="wc-eventtitle">Collectors' swap</div>
              <p class="wc-panelbody">
                Bring singles, figures and back issues to trade. Tables free for members, all
                welcome.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== VISIT ===================== */}
    <section id="visit" class="wc-visit">
      <div class="wc-visit-inner">
        <div>
          <div class="wc-eyebrow" style="color:#e63a2e;margin-bottom:8px;">Visit the shop</div>
          <h2 class="wc-h2" style="margin-bottom:22px;">Come in &amp; browse</h2>
          <div class="wc-address">Newtown Road<br />Newtown, Waterford City</div>

          <table class="wc-hours">
            <tbody>
              <tr><td>Mon – Fri</td><td>10:00 – 17:00</td></tr>
              <tr><td>Saturday</td><td>10:00 – 18:00</td></tr>
              <tr><td>Sunday</td><td>12:00 – 17:00</td></tr>
            </tbody>
          </table>

          <div class="wc-visit-btns">
            <span class="wc-btnwrap" data-anglebtn data-drop="#15121d" data-off="8,10">
              <a
                href="https://maps.google.com/?q=Newtown+Road+Waterford"
                target="_blank"
                rel="noopener"
                class="wc-btn"
                style="--ax:8px;--ay:9px;font-size:13px;letter-spacing:.08em;background:#e63a2e;color:#fbf7ee;padding:13px 20px;"
                >Get directions</a
              >
            </span>
            {/* Placeholder number from the concept — confirm the shop's real
                line before sending this link to them. */}
            <span class="wc-btnwrap" data-anglebtn data-drop="#e63a2e" data-off="8,10">
              <a
                href="tel:+353833248821"
                class="wc-btn"
                style="--ax:8px;--ay:9px;font-size:13px;letter-spacing:.08em;background:#fbf7ee;color:#15121d;padding:13px 20px;"
                >Call the shop</a
              >
            </span>
          </div>
        </div>

        <div class="wc-map">
          <div class="wc-map-road-v"></div>
          <div class="wc-map-road-h"></div>
          <div class="wc-map-pin">
            <div class="wc-map-pinlabel">We're here</div>
            <div class="wc-map-pindot"></div>
          </div>
          <div class="wc-map-note">▢ map placeholder — swap for embed</div>
        </div>
      </div>
    </section>

    {/* ===================== FOOTER ===================== */}
    <footer class="wc-footer">
      <div class="wc-footer-inner">
        <div>
          <div class="wc-logo" style="font-size:24px;">
            <span>Waterford</span><span class="wc-logo-accent">Comics</span><span class="wc-logo-dot"></span>
          </div>
          <p style="max-width:24em;color:#bdb6a8;font-size:15px;margin:16px 0 0;">
            A family-run comic, manga, trading-card and collectibles shop on Newtown Road — with a
            café next door and a pull list with your name on it.
          </p>
        </div>
        <div>
          <div class="wc-footer-head">Shop</div>
          <div class="wc-footer-links">
            <a href="#shop">New this week</a>
            <a href="#shop">Comics &amp; manga</a>
            <a href="#shop">Trading cards</a>
            <a href="#shop">Figures &amp; merch</a>
          </div>
        </div>
        <div>
          <div class="wc-footer-head">Members</div>
          <div class="wc-footer-links">
            <a href="#pulllist">Join the pull list</a>
            <a href="#events">League nights</a>
