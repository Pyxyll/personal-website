  .wc-map-pinlabel {
    background: #15121d;
    color: #fbf7ee;
    font-family: "Space Mono", monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 5px 9px;
    border: 2px solid #fbf7ee;
    white-space: nowrap;
    margin-bottom: 6px;
  }
  .wc-map-pindot {
    width: 30px;
    height: 30px;
    background: #e63a2e;
    border: 3px solid #15121d;
    border-radius: 50% 50% 50% 0;
    transform: rotate(45deg);
    box-shadow: 3px 3px 0 rgba(21, 18, 29, 0.3);
  }
  .wc-map-note {
    position: absolute;
    bottom: 10px;
    right: 12px;
    font-family: "Space Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: #8a8f84;
  }

  /* --- footer --- */
  .wc-footer {
    background: #15121d;
    color: #fbf7ee;
    padding: 54px 24px 0;
  }
  .wc-footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 34px;
    padding-bottom: 42px;
  }
  .wc-footer-head {
    font-family: "Space Mono", monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #e63a2e;
    margin-bottom: 14px;
  }
  .wc-footer-links {
    display: flex;
    flex-direction: column;
    gap: 9px;
    font-size: 15px;
    color: #d7d0c2;
  }
  .wc-footer-rule {
    border-top: 3px solid #2b2536;
  }
  .wc-footer-legal {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 0 26px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-family: "Space Mono", monospace;
    font-size: 11.5px;
    letter-spacing: 0.06em;
    color: #8d8678;
  }

  /* --- responsive: the concept is drawn wide, so collapse the paired grids --- */
  @media (max-width: 880px) {
    .wc-nav-desktop {
      display: none;
    }
    .wc-burger {
      display: flex;
    }
    .wc-hero-inner,
    .wc-pull-inner,
    .wc-cafe,
    .wc-visit-inner {
      grid-template-columns: 1fr;
    }
    .wc-hero-aside {
      min-height: 230px;
    }
    .wc-bubble {
      position: relative;
      top: 0;
      max-width: none;
    }
    .wc-stamp {
      display: none;
    }
    .wc-cafe-art {
      border-right: 0;
      border-bottom: 7px solid #15121d;
    }
    .wc-cafe-body {
      padding: 44px 24px;
    }
    .wc-footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .wc-ribbon-text {
      font-size: 17px;
    }
  }
  @media (max-width: 560px) {
    .wc-ticks {
      grid-template-columns: 1fr;
    }
    .wc-hero-btns,
    .wc-visit-btns {
      gap: 22px;
    }
    .wc-footer-inner {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html:has(.wc) {
      scroll-behavior: auto;
    }
    .wc * {
      transition: none !important;
    }
  }
</style>

<script>
  // Mobile menu ------------------------------------------------------------
  const burger = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("#wc-menu");

  function setMenu(open: boolean) {
    if (!burger || !menu) return;
    menu.hidden = !open;
    burger.setAttribute("aria-expanded", String(open));
  }

  burger?.addEventListener("click", () => setMenu(menu?.hidden === true));
  document.querySelectorAll("[data-menu-close]").forEach((el) => {
    el.addEventListener("click", () => setMenu(false));
  });
  // The menu is a mobile affordance; widening past the breakpoint must not
  // leave it stranded open behind the desktop nav.
  const wide = window.matchMedia("(min-width: 881px)");
  wide.addEventListener("change", (e) => {
    if (e.matches) setMenu(false);
  });

  // Pull-list form — swaps to a confirmation, nothing is sent anywhere -------
  const form = document.querySelector<HTMLFormElement>("[data-pull-form]");
  const confirm = document.querySelector<HTMLElement>("[data-pull-confirm]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.reset();
    form.hidden = true;
    if (confirm) confirm.hidden = false;
  });

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Reveal on scroll -------------------------------------------------------
  if (!reduce) {
    const els = Array.from(document.querySelectorAll<HTMLElement>("[data-wc-reveal]"));
    els.forEach((el) => {
      el.style.opacity = "0";
      el.style.transform = "translateY(22px)";
      el.style.transition = "opacity .55s ease, transform .55s ease";
      el.style.willChange = "opacity, transform";
    });
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          el.style.opacity = "1";
          // Clearing the inline transform hands the card back to the
          // stylesheet, so the tilt and hover lift still work afterwards.
          el.style.transform = "";
          io.unobserve(el);
        });
      },
      { threshold: 0.12 }
    );
    els.forEach((el) => io.observe(el));
  }

  // Hand-drawn drop shadow behind every button ------------------------------
  // A polygon offset behind the face; on hover each vertex wanders on its own
  // sine so the shadow looks inked rather than printed.
  const SVGNS = "http://www.w3.org/2000/svg";
  const cfg = [
    [2.0, 1.7, 0.0, 2.0, 1.3, 1.1], // top-left, mostly tucked behind the face
    [4.0, 1.1, 2.0, 2.0, 1.9, 0.4], // top-right
    [8.0, 1.45, 0.7, 6.0, 1.15, 3.0], // bottom-right, the loosest corner
    [5.0, 1.3, 4.2, 7.5, 1.55, 0.9], // bottom-left
  ];
  const fmt = (pts: number[][]) =>
    pts.map((p) => `${Math.round(p[0] * 10) / 10},${Math.round(p[1] * 10) / 10}`).join(" ");

  function buildDrop(el: HTMLElement) {
    const face = el.querySelector<HTMLElement>("a, button");
    if (!face) return;
    const [ox, oy] = (el.dataset.off || "9,11").split(",").map(Number);
    const w = face.offsetWidth;
    const h = face.offsetHeight;
    if (!w || !h) return;

    const svg = document.createElementNS(SVGNS, "svg");
    const vw = w + ox + 16;
    const vh = h + oy + 14;
    svg.setAttribute("width", String(vw));
    svg.setAttribute("height", String(vh));
    svg.setAttribute("viewBox", `0 0 ${vw} ${vh}`);
    svg.style.cssText =
      "position:absolute;left:0;top:0;overflow:visible;pointer-events:none;z-index:0;";

    const poly = document.createElementNS(SVGNS, "polygon");
    poly.setAttribute("fill", el.dataset.drop || "#15121d");
    const rest = [
      [ox, oy],
      [ox + w, oy],
      [ox + w, oy + h],
      [ox, oy + h],
    ];
    poly.setAttribute("points", fmt(rest));
    svg.appendChild(poly);
    el.insertBefore(svg, el.firstChild);

    if (reduce) return; // static offset rectangle, no wander

    let raf: number | null = null;
    let t0 = 0;
    let last = 0;
    let amp = 0;
    let target = 0;

    const frame = (ts: number) => {
      if (!t0) {
        t0 = ts;
        last = ts;
      }
      const t = (ts - t0) / 1000;
      const dt = Math.min(0.05, (ts - last) / 1000);
      last = ts;
      // Ease the amplitude rather than the vertices, so the wander fades in
      // and out smoothly instead of snapping on hover.
      amp += (target - amp) * (1 - Math.exp(-dt / 0.16));
      poly.setAttribute(
        "points",
        fmt(
          rest.map((b, i) => {
            const c = cfg[i];
            return [
              b[0] + amp * c[0] * Math.sin(t * c[1] + c[2]),
              b[1] + amp * c[3] * Math.sin(t * c[4] + c[5]),
            ];
          })
        )
      );
      if (target === 0 && amp < 0.003) {
        poly.setAttribute("points", fmt(rest));
        raf = null;
        return;
      }
      raf = requestAnimationFrame(frame);
    };

    const run = () => {
      if (raf === null) {
        t0 = 0;
        raf = requestAnimationFrame(frame);
      }
    };
    el.addEventListener("mouseenter", () => {
      target = 1;
      run();
    });
    el.addEventListener("mouseleave", () => {
      target = 0;
      run();
    });
  }

  // Wait for webfonts: the shadow is sized off the rendered face, and Anton
  // swapping in after would leave every shadow the wrong width.
  const initDrops = () =>
    document.querySelectorAll<HTMLElement>("[data-anglebtn]").forEach(buildDrop);
  if (document.fonts?.ready) {
    document.fonts.ready.then(initDrops);
  } else {
    initDrops();
  }
</script>
