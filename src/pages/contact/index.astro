---
import Base from "../../layouts/Base.astro";
import Schema from "../../components/Schema.astro";
import { contactPageSchema, breadcrumbSchema } from "../../lib/schema";
import { site } from "../../lib/site";

const pageUrl = new URL("/contact/", site.url).toString();
---

<Base
  title="Contact — Dylan Collins"
  description="Get in touch — email or a quick form, whichever you prefer."
>
  <Schema
    slot="head"
    data={[
      contactPageSchema({ url: pageUrl }),
      breadcrumbSchema([
        { name: "Home", url: site.url + "/" },
        { name: "Contact", url: pageUrl },
      ]),
    ]}
  />
  <section class="mx-auto max-w-6xl px-6 lg:px-10 py-16 sm:py-24">
    <header class="grid grid-cols-12 gap-6 lg:gap-10 mb-16 lg:mb-24">
      <div class="hidden lg:block lg:col-span-2 section-num lift">004 / Contact</div>
      <div class="col-span-12 lg:col-span-10 flex flex-col gap-5">
        <h1 class="display text-[clamp(2.75rem,7vw,4.5rem)] lift lift-1">
          Say hi<span class="text-accent">.</span>
        </h1>
        <p class="text-lg text-ink-dim max-w-2xl lift lift-2">
          Freelance brief, a quick question, or a "did you ever finish that
          side project" — all welcome. Fastest by email.
        </p>
      </div>
    </header>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Direct</div>
      <address class="col-span-12 lg:col-span-10 flex flex-col gap-4 not-italic">
        <a href="mailto:hello@dylancollins.me" class="text-3xl sm:text-4xl font-semibold tracking-tight link inline-block self-start" rel="author">
          hello@dylancollins.me
        </a>
        <ul class="flex flex-wrap gap-x-8 gap-y-2 font-mono text-xs uppercase tracking-widest text-ink-dim">
          <li><a href="https://github.com/pyxyll" target="_blank" rel="me noopener" class="link">GitHub ↗</a></li>
          <li><a href="https://www.linkedin.com/in/dylan-c-collins/" target="_blank" rel="me noopener" class="link">LinkedIn ↗</a></li>
        </ul>
      </address>
    </div>

    <div class="rule my-12 lg:my-16"></div>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Form</div>
      <div class="col-span-12 lg:col-span-10">
        {/* Formspree-style action target — replace endpoint with your real one */}
        <form
          action="https://formspree.io/f/REPLACE_ME"
          method="POST"
          class="grid gap-6 max-w-2xl"
        >
          <label class="grid gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-ink-faint">Name</span>
            <input
              type="text"
              name="name"
              required
              class="bg-transparent border-b border-rule-strong py-3 text-lg focus:border-accent focus:outline-none transition-colors"
            />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-ink-faint">Email</span>
            <input
              type="email"
              name="email"
              required
              class="bg-transparent border-b border-rule-strong py-3 text-lg focus:border-accent focus:outline-none transition-colors"
            />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-ink-faint">Message</span>
            <textarea
              name="message"
              rows="5"
              required
              class="bg-transparent border-b border-rule-strong py-3 text-lg focus:border-accent focus:outline-none transition-colors resize-y"
            ></textarea>
          </label>
          <div>
            <button
              type="submit"
              class="inline-flex items-center gap-3 border border-rule-strong px-6 py-4 font-mono text-xs uppercase tracking-widest hover:border-accent hover:text-accent transition-colors"
            >
              Send
              <span aria-hidden="true">→</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Base>
