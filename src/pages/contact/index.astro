---
import Base from "../../layouts/Base.astro";
import Schema from "../../components/Schema.astro";
import { contactPageSchema, breadcrumbSchema } from "../../lib/schema";
import { site } from "../../lib/site";

const pageUrl = new URL("/contact/", site.url).toString();
---

<Base
  title="Contact — Dylan Collins"
  description="Get in touch — email or a quick form, whichever you prefer."
>
  <Schema
    slot="head"
    data={[
      contactPageSchema({ url: pageUrl }),
      breadcrumbSchema([
        { name: "Home", url: site.url + "/" },
        { name: "Contact", url: pageUrl },
      ]),
    ]}
  />
  <section class="mx-auto max-w-6xl px-6 lg:px-10 py-16 sm:py-24">
    <header class="grid grid-cols-12 gap-6 lg:gap-10 mb-16 lg:mb-24">
      <div class="hidden lg:block lg:col-span-2 section-num lift">004 / Contact</div>
      <div class="col-span-12 lg:col-span-10 flex flex-col gap-5">
        <h1 class="display text-[clamp(2.75rem,7vw,4.5rem)] lift lift-1">
          Say hi<span class="text-accent">.</span>
        </h1>
        <p class="text-lg text-ink-dim max-w-2xl lift lift-2">
          Freelance brief, a quick question, or a "did you ever finish that
          side project" — all welcome. Fastest by email.
        </p>
      </div>
    </header>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Direct</div>
      <address class="col-span-12 lg:col-span-10 flex flex-col gap-4 not-italic">
        <a href="mailto:hello@dylancollins.me" class="text-3xl sm:text-4xl font-semibold tracking-tight link inline-block self-start" rel="author">
          hello@dylancollins.me
        </a>
        <ul class="flex flex-wrap gap-x-8 gap-y-2 font-mono text-xs uppercase tracking-widest text-ink-dim">
          <li><a href="https://github.com/pyxyll" target="_blank" rel="me noopener" class="link">GitHub ↗</a></li>
          <li><a href="https://www.linkedin.com/in/dylan-c-collins/" target="_blank" rel="me noopener" class="link">LinkedIn ↗</a></li>
        </ul>
      </address>
    </div>

    <div class="rule my-12 lg:my-16"></div>

    <div class="grid grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <div class="col-span-12 lg:col-span-2 section-num">Form</div>
      <div class="col-span-12 lg:col-span-10">
        <form
          id="contact-form"
          action={site.contactEndpoint}
          method="POST"
          class="grid gap-6 max-w-2xl"
        >
          <label class="grid gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-ink-faint">Name</span>
            <input
              type="text"
              name="name"
              required
              maxlength="100"
              autocomplete="name"
              class="bg-transparent border-b border-rule-strong py-3 text-lg focus:border-accent focus:outline-none transition-colors"
            />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-ink-faint">Email</span>
            <input
              type="email"
              name="email"
              required
              maxlength="200"
              autocomplete="email"
              class="bg-transparent border-b border-rule-strong py-3 text-lg focus:border-accent focus:outline-none transition-colors"
            />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-ink-faint">Message</span>
            <textarea
              name="message"
              rows="5"
              required
              maxlength="5000"
              class="bg-transparent border-b border-rule-strong py-3 text-lg focus:border-accent focus:outline-none transition-colors resize-y"
            ></textarea>
          </label>

          {/* Honeypot — hidden from humans, catches bots. Never fill this. */}
          <div aria-hidden="true" class="absolute -left-[9999px] h-0 w-0 overflow-hidden" hidden>
            <label>
              Company
              <input type="text" name="company" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <div class="flex items-center gap-4">
            <button
              type="submit"
              class="inline-flex items-center gap-3 border border-rule-strong px-6 py-4 font-mono text-xs uppercase tracking-widest hover:border-accent hover:text-accent transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span data-label>Send</span>
              <span aria-hidden="true">→</span>
            </button>
            <p
              id="contact-status"
              role="status"
              aria-live="polite"
              class="font-mono text-xs uppercase tracking-widest"
            ></p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script>
    // Progressive enhancement: intercept the submit, POST JSON to the Worker,
    // and show inline status. Without JS the form still POSTs natively to the
    // Worker (form-encoded), which the Worker also accepts.
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("contact-status");
    const button = form?.querySelector("button[type=submit]") as HTMLButtonElement | null;
    const label = form?.querySelector("[data-label]");

    if (form && status && button && label) {
      const setStatus = (msg: string, tone: "ok" | "err" | "") => {
        status.textContent = msg;
        status.style.color =
          tone === "ok" ? "var(--color-accent)" : tone === "err" ? "#f87171" : "var(--color-ink-faint)";
      };

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));

        button.disabled = true;
        label.textContent = "Sending";
        setStatus("", "");

        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });
          const body = await res.json().catch(() => ({}));

          if (res.ok) {
            form.reset();
            label.textContent = "Sent";
            setStatus("Got it — I'll be in touch.", "ok");
          } else {
            button.disabled = false;
            label.textContent = "Send";
            setStatus(body.error ?? "Something went wrong. Try again?", "err");
          }
        } catch {
          button.disabled = false;
          label.textContent = "Send";
          setStatus("Network error. Try again?", "err");
        }
      });
    }
  </script>
</Base>
